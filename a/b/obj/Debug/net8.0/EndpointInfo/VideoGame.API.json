  "components": {
    "schemas": {
      "PlatformDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "manufacturer": {
            "type": "string",
            "nullable": true
          },
          "launchYear": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PublisherDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "website": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SaveDeveloperDto": {
        "required": [
          "country",
          "foundedYear",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 150,
            "minLength": 2,
            "type": "string"
          },
          "country": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "foundedYear": {
            "maximum": 2100,
            "minimum": 1800,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "SaveGameDto": {
        "required": [
          "developerId",
          "genre",
          "price",
          "publisherId",
          "releaseDate",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 200,
            "minLength": 2,
            "type": "string"
          },
          "genre": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "releaseDate": {
            "type": "string",
            "format": "date-time"
          },
          "price": {
            "maximum": 999.99,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "developerId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "publisherId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
